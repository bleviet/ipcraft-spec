{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ipcraft.dev/schemas/data_inspector.schema.json",
  "title": "IPCraft Data Inspector Recipe",
  "description": "Shareable Data Inspector definitions. Transient sample values and capture histories are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "sources", "fields", "overlayGroups", "steps", "outputs", "view"],
  "properties": {
    "version": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "default": "" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/field" }
    },
    "overlayGroups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/overlayGroup" }
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/output" }
    },
    "view": { "$ref": "#/$defs/view" }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "width"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1, "maximum": 4096 }
      }
    },
    "importProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceFile", "registerName"],
      "properties": {
        "sourceFile": { "type": "string", "minLength": 1 },
        "registerName": { "type": "string", "minLength": 1 }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interpretation"],
      "properties": {
        "interpretation": {
          "enum": ["hex", "binary", "unsigned", "signed", "enum", "float", "fixedPoint"]
        },
        "fractionalBits": { "type": "integer", "minimum": 0, "maximum": 4095 },
        "expectedValue": { "type": "string" }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sourceId", "name", "msb", "lsb", "groupId", "display"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "sourceId": { "$ref": "#/$defs/stableId" },
        "name": { "type": "string", "minLength": 1 },
        "msb": { "type": "integer", "minimum": 0, "maximum": 4095 },
        "lsb": { "type": "integer", "minimum": 0, "maximum": 4095 },
        "groupId": { "$ref": "#/$defs/stableId" },
        "description": { "type": "string" },
        "enumValues": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "importProvenance": { "$ref": "#/$defs/importProvenance" },
        "display": { "$ref": "#/$defs/display" }
      }
    },
    "overlayGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "inputId"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "type": {
          "enum": [
            "concat",
            "slice",
            "and",
            "or",
            "xor",
            "not",
            "shiftLeft",
            "shiftRight",
            "zeroExtend",
            "signExtend",
            "truncate",
            "byteSwap"
          ]
        },
        "inputId": { "$ref": "#/$defs/stableId" },
        "operandId": { "$ref": "#/$defs/stableId" },
        "msb": { "type": "integer", "minimum": 0, "maximum": 4095 },
        "lsb": { "type": "integer", "minimum": 0, "maximum": 4095 },
        "amount": { "type": "integer", "minimum": 0, "maximum": 4096 },
        "width": { "type": "integer", "minimum": 1, "maximum": 4096 }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "valueId"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "type": "string", "minLength": 1 },
        "valueId": { "$ref": "#/$defs/stableId" }
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["laneWidth", "zoom"],
      "properties": {
        "laneWidth": { "enum": [8, 16, 32, 64] },
        "zoom": { "enum": ["overview", "field", "bit"] },
        "selectedOutputId": { "$ref": "#/$defs/stableId" },
        "selectedGroupId": { "$ref": "#/$defs/stableId" }
      }
    }
  }
}
